# ==================== DATABASE ====================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=farmapatria
DB_USER=postgres
DB_PASS=changeme
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_POOL_TIMEOUT=30

# ==================== SCRAPING RANGE ====================
START_ID=42022341
END_ID=42591276

# ==================== PERFORMANCE ====================
CONCURRENCY=40
BATCH_SIZE=2000
REQUEST_TIMEOUT=60
MAX_RETRIES=5
DELAY_MS=50

# ==================== WORKERS (Multi-Worker) ====================
WORKER_ID=0              # ID del worker (0 = single mode, 1-N = multi-worker)
NUM_WORKERS=0            # 0 = auto-detectar (cores * 2)

# ==================== ANTI-BLOCK (Sin Proxies) ====================
ENABLE_UA_ROTATION=true          # Rotar User Agents
ENABLE_FINGERPRINT_RANDOMIZATION=true  # Randomizar fingerprint
DELAY_MIN_MS=100                  # Delay mínimo entre requests (ms)
DELAY_MAX_MS=500                  # Delay máximo entre requests (ms)
BLOCK_DETECTION=true              # Detectar bloqueos automáticamente
COOLDOWN_SECONDS=60               # Espera después de bloqueo

# ==================== RATE LIMITING ====================
RATE_LIMIT_RPS=15
CIRCUIT_BREAKER_THRESHOLD=10
CIRCUIT_BREAKER_TIMEOUT=300

# ==================== MONITORING ====================
LOG_LEVEL=INFO
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=30

# ==================== ADVANCED ====================
ENABLE_ADAPTIVE_PARSING=true
ENABLE_ROBOTS_TXT=false
IMPERSONATE_BROWSER=chrome
USE_PROXIES=false
PROXY_LIST=
CHECKPOINT_DIR=./checkpoints